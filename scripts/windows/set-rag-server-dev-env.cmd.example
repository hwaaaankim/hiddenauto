@echo off
rem Copy this file to set-rag-server-dev-env.cmd, fill values, run it in the same CMD, and never commit it.
set "PGHOST=127.0.0.1"
set "PGPORT=15433"
set "PGUSER=ax_admin"
set "PGDATABASE=ax_rag_dev"
set "PGPASSWORD=CHANGE_ME_DEV_ADMIN_PASSWORD"
set "HIDDENBATH_RAG_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:15433/ax_rag_dev"
set "HIDDENBATH_RAG_DATASOURCE_USERNAME=ax_rag_dev_user"
set "HIDDENBATH_RAG_DATASOURCE_PASSWORD=CHANGE_ME_DEV_DB_PASSWORD"
set "HIDDENBATH_RAG_OPENAI_API_KEY=CHANGE_ME_ROTATED_OPENAI_KEY"
set "HIDDENBATH_RAG_OPENAI_CHAT_MODEL=gpt-5.5"
set "HIDDENBATH_RAG_OPENAI_EMBEDDING_MODEL=text-embedding-3-small"
set "HIDDENBATH_RAG_OPENAI_SEMANTIC_WORKER_ENABLED=true"
